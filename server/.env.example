# Required
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret

# Optional hardening
SALT_ROUNDS=12
RESET_CODE_TTL_MINUTES=15

# SQLite path (set this to a mounted disk path in Render)
SQLITE_PATH=/var/data/health.db

# SMTP (required for reset code email delivery in production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=example-user
SMTP_PASS=example-password
SMTP_FROM=no-reply@example.com
