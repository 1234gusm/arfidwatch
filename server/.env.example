# Required
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret

# Optional hardening
SALT_ROUNDS=12
RESET_CODE_TTL_MINUTES=15

# SQLite path
# - If you attach a Render disk at /var/data, use /var/data/health.db
# - If no disk is attached yet, omit SQLITE_PATH and the app will use server/data/health.db
SQLITE_PATH=/var/data/health.db

# Production safety:
# - leave unset to require a writable persistent DB path in production
# - set to true only if you intentionally allow ephemeral fallback
# SQLITE_ALLOW_EPHEMERAL=true

# SMTP (required for reset code email delivery in production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=example-user
SMTP_PASS=example-password
SMTP_FROM=no-reply@example.com
